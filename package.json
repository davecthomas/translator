{
  "name": "hebrew-live-translator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Real-time bidirectional English/Hebrew voice translator using Web Speech API and the Anthropic API",
  "scripts": {
    "go": "./start.sh",
    "dev": "concurrently -n server,web -c yellow,cyan \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:server": "node --env-file-if-exists=.env server/index.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node --env-file-if-exists=.env server/index.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0"
  }
}
